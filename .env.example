PORT=3000

# Your Auth0 domain WITHOUT protocol, e.g. "dev-abc123.us.auth0.com"
AUTH0_DOMAIN=

# Auth0 application (client) id
AUTH0_CLIENT_ID=

# Database connection name (realm), usually "Username-Password-Authentication"
AUTH0_DB_CONNECTION=Username-Password-Authentication

# Optional
# AUTH0_AUDIENCE=
# AUTH0_REDIRECT_URI=http://localhost:3000/callback
# AUTH0_LOGOUT_RETURN_TO=http://localhost:3000/

