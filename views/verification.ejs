<%- include("partials/header", { title: "Verification", auth0Config }) %>

<section class="card">
  <h1>Cross-origin verification</h1>
  <p class="muted">
    Auth0 loads this page when it needs to complete cross-origin authentication verification.
  </p>
  <div id="verification-result" class="result" aria-live="polite"></div>
</section>

<script>
  (function () {
    // This page is based on Auth0’s sample verification callback:
    // `auth0Client.crossOriginVerification()` invoked on a page configured as the
    // Cross-Origin Verification Fallback URL.
    // See: `https://raw.githubusercontent.com/auth0/lock/master/support/callback-cross-auth.html`
    function run() {
      if (!window.auth0 || !window.__AUTH0_CONFIG__) return false;

      const el = document.getElementById("verification-result");
      const cfg = window.__AUTH0_CONFIG__ || {};

      try {
        const auth0Client = new auth0.WebAuth({
          domain: cfg.domain,
          clientID: cfg.clientID,
          // Auth0's sample includes redirectUri pointing at the verification page itself.
          redirectUri: window.location.origin + "/verification"
        });

        auth0Client.crossOriginVerification();
        if (el) el.textContent = "Completing verification…";
        return true;
      } catch (e) {
        if (el) {
          el.textContent = e && e.message ? e.message : "Verification failed.";
        }
        return true;
      }
    }

    if (run()) return;
    const id = setInterval(function () {
      if (run()) clearInterval(id);
    }, 25);
    setTimeout(function () {
      clearInterval(id);
    }, 2000);
  })();
</script>

<%- include("partials/footer") %>

