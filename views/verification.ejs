<%- include("partials/header", { title: "Verification", auth0Config }) %>

<section class="card">
  <h1>Cross-origin verification</h1>
  <p class="muted">
    Auth0 loads this page when it needs to complete cross-origin authentication verification.
  </p>
  <div id="verification-result" class="result" aria-live="polite"></div>
</section>

<script>
  (function () {
    function hasExpectedContext() {
      const search = new URLSearchParams(window.location.search || "");
      const hash = new URLSearchParams(
        (window.location.hash || "").startsWith("#")
          ? (window.location.hash || "").slice(1)
          : window.location.hash || ""
      );

      // Auth0 will typically pass parameters needed for verification. If this
      // page is opened directly, auth0.js may fail with postMessage targetOrigin
      // errors (e.g. "invalid target origin undefined").
      return (
        search.has("origin") ||
        hash.has("origin") ||
        search.has("type") ||
        hash.has("type")
      );
    }

    // auth0.js is loaded in the footer; run as soon as it's available.
    function run() {
      try {
        if (!window.AuthDemo || !window.AuthDemo.webAuth) return false;
        const el = document.getElementById("verification-result");

        if (!hasExpectedContext()) {
          if (el) {
            el.textContent =
              "This page is meant to be opened by Auth0 during embedded login verification. " +
              "If you opened it directly, go back to /login and try again.";
          }
          return true;
        }

        window.AuthDemo.webAuth.crossOriginVerification();
        if (el) el.textContent = "Completing verification…";
        return true;
      } catch (e) {
        const el = document.getElementById("verification-result");
        if (el) el.textContent = e && e.message ? e.message : "Verification failed.";
        return true;
      }
    }

    if (run()) return;
    const id = setInterval(function () {
      if (run()) clearInterval(id);
    }, 25);
    setTimeout(function () {
      clearInterval(id);
    }, 2000);
  })();
</script>

<%- include("partials/footer") %>

